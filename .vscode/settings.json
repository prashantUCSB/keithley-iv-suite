{
    // ── Python interpreter ────────────────────────────────────────────
    // Points to the local virtual environment created by install_windows.bat
    // VSCode will show this in the bottom status bar as "Python (.venv)"
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "python.terminal.activateEnvironment": true,
    "python.terminal.activateEnvInCurrentTerminal": true,

    // ── Editor quality-of-life ────────────────────────────────────────
    "editor.formatOnSave": true,
    "editor.rulers": [100],
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "files.trimTrailingWhitespace": true,

    // ── File associations ─────────────────────────────────────────────
    "files.associations": {
        "*.yaml": "yaml",
        "*.yml":  "yaml"
    },

    // ── Terminal — open in the project root ───────────────────────────
    "terminal.integrated.cwd": "${workspaceFolder}",

    // ── Hide clutter from the Explorer sidebar ────────────────────────
    "files.exclude": {
        "**/__pycache__":  true,
        "**/*.pyc":        true,
        "**/.pytest_cache": true,
        "**/htmlcov":      true
    }
}
